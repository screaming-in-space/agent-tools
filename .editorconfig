# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{json,xml,yml,yaml,props,targets,csproj,slnx}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.cs]

# Default severity for analyzer diagnostics with category 'Style'
dotnet_analyzer_diagnostic.category-Style.severity = suggestion

# Braces - always required
csharp_prefer_braces = true:error

# Namespace declarations - file-scoped
csharp_style_namespace_declarations = file_scoped:warning

# Primary constructors
csharp_style_prefer_primary_constructors = true:suggestion

# Expression body
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion

# var preferences
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# Using directives
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = outside_namespace:warning

# Null checks
csharp_style_prefer_is_null_check_expression = true:suggestion
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_null_propagation = true:suggestion

# CA1873: Avoid potentially expensive logging
dotnet_diagnostic.CA1873.severity = silent

# CA1305: StringBuilder interpolation locale — all tool output is invariant English
dotnet_diagnostic.CA1305.severity = silent

# CA1848: LoggerMessage delegates — overkill for CLI agent with few log calls
dotnet_diagnostic.CA1848.severity = silent

# CA1707: Underscores in test names — standard xUnit Method_Scenario_Expected convention
dotnet_diagnostic.CA1707.severity = silent

# xUnit1051: CancellationToken pass-through — test file I/O and fake HTTP don't need cancellation
dotnet_diagnostic.xUnit1051.severity = suggestion
