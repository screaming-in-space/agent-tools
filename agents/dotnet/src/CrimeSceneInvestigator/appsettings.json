{
  "Serilog": {
    "MinimumLevel": {
      "Override": {
        "System.Net.Http": "Warning",
        "Microsoft": "Warning"
      }
    }
  },
  "Models": {
    "default": {
      "Endpoint": "http://localhost:1234/v1",
      "ApiKey": "no-key",
      "Model": "unsloth/nvidia-nemotron-3-nano-4b",
      "Temperature": 0.3,
      "MaxOutputTokens": 4096
    },
    "embedding": {
      "Endpoint": "http://localhost:1234/v1",
      "ApiKey": "no-key",
      "Model": "jina-embeddings-v5-text-nano-retrieval"
    }
  }
}
